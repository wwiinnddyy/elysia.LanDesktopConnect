<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Elysia.LanDesktopConnect.Settings"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             x:Class="Elysia.LanDesktopConnect.Settings.IpcBridgeSettingsPage"
             x:DataType="vm:IpcBridgeSettingsViewModel">

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Classes="settings-page-container" Spacing="12">
      <TextBlock Text="{Binding PageDescription}"
                 Opacity="0.72"
                 TextWrapping="Wrap" />

      <Border IsVisible="{Binding HasError}"
              Padding="12"
              CornerRadius="8"
              Background="#22D13438"
              BorderBrush="#88D13438"
              BorderThickness="1">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
          <TextBlock Text="{Binding LastError}"
                     TextWrapping="Wrap"
                     VerticalAlignment="Center" />
          <Button Grid.Column="1"
                  Command="{Binding ClearErrorCommand}"
                  Content="×"
                  MinWidth="32" />
        </Grid>
      </Border>

      <ui:FASettingsExpander Header="{Binding BunHeader}"
                           Description="{Binding BunStatusDescription}"
                           IsExpanded="True">
        <ui:FASettingsExpander.Footer>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Command="{Binding InstallBunCommand}"
                    Content="{Binding InstallGuideText}"
                    IsVisible="{Binding IsBunNotInstalled}" />
            <TextBlock Text="{Binding ReadyText}"
                       IsVisible="{Binding IsBunInstalled}"
                       Opacity="0.72"
                       VerticalAlignment="Center" />
          </StackPanel>
        </ui:FASettingsExpander.Footer>

        <ui:FASettingsExpanderItem IsVisible="{Binding IsBunInstalled}">
          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
            <TextBlock Text="{Binding VersionLabel}" Opacity="0.72" />
            <TextBlock Grid.Column="1"
                       Text="{Binding BunVersion}"
                       HorizontalAlignment="Right" />
          </Grid>
        </ui:FASettingsExpanderItem>

        <ui:FASettingsExpanderItem IsVisible="{Binding IsBunInstalled}">
          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
            <TextBlock Text="{Binding PathLabel}" Opacity="0.72" />
            <TextBlock Grid.Column="1"
                       Text="{Binding BunPath}"
                       HorizontalAlignment="Right"
                       FontSize="12"
                       Opacity="0.65"
                       TextTrimming="CharacterEllipsis" />
          </Grid>
        </ui:FASettingsExpanderItem>

        <ui:FASettingsExpanderItem>
          <Button Command="{Binding CheckBunCommand}"
                  Content="{Binding CheckAgainText}"
                  HorizontalAlignment="Right" />
        </ui:FASettingsExpanderItem>
      </ui:FASettingsExpander>

      <ui:FASettingsExpander Header="{Binding GatewayHeader}"
                           Description="{Binding GatewayStatusDescription}"
                           IsExpanded="True">
        <ui:FASettingsExpander.Footer>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Command="{Binding ToggleGatewayCommand}"
                    Content="{Binding ToggleGatewayButtonText}"
                    IsEnabled="{Binding CanToggleGateway}" />
            <Button Command="{Binding RestartGatewayCommand}"
                    Content="{Binding RestartText}"
                    IsVisible="{Binding IsGatewayRunning}" />
          </StackPanel>
        </ui:FASettingsExpander.Footer>

        <ui:FASettingsExpanderItem IsVisible="{Binding IsGatewayRunning}">
          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
            <TextBlock Text="{Binding PortLabel}" />
            <TextBlock Grid.Column="1"
                       Text="{Binding GatewayPortText}"
                       HorizontalAlignment="Right"
                       FontWeight="SemiBold" />
          </Grid>
        </ui:FASettingsExpanderItem>

        <ui:FASettingsExpanderItem IsVisible="{Binding IsGatewayRunning}">
          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
            <TextBlock Text="{Binding UptimeLabel}" />
            <TextBlock Grid.Column="1"
                       Text="{Binding GatewayUptimeText}"
                       HorizontalAlignment="Right" />
          </Grid>
        </ui:FASettingsExpanderItem>

        <ui:FASettingsExpanderItem IsVisible="{Binding IsGatewayRunning}">
          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
            <TextBlock Text="{Binding ConnectedAppsLabel}" />
            <TextBlock Grid.Column="1"
                       Text="{Binding ConnectedAppsCountText}"
                       HorizontalAlignment="Right" />
          </Grid>
        </ui:FASettingsExpanderItem>

        <ui:FASettingsExpanderItem>
          <Button Command="{Binding ViewLogsCommand}"
                  Content="{Binding ViewLogsText}"
                  HorizontalAlignment="Right" />
        </ui:FASettingsExpanderItem>
      </ui:FASettingsExpander>

      <ui:FASettingsExpander Header="{Binding ConnectedAppsHeader}"
                           Description="{Binding ConnectedAppsDescription}"
                           IsExpanded="{Binding IsGatewayRunning}">
        <ui:FASettingsExpander.Footer>
          <Button Command="{Binding RefreshAppsCommand}"
                  Content="{Binding RefreshText}" />
        </ui:FASettingsExpander.Footer>

        <ItemsControl ItemsSource="{Binding ConnectedApps}"
                      IsVisible="{Binding HasConnectedApps}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:ConnectedAppViewModel">
              <ui:FASettingsExpanderItem>
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                  <TextBlock Text="●" VerticalAlignment="Center" />
                  <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding AppName}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding AppDetails}"
                               FontSize="12"
                               Opacity="0.65" />
                  </StackPanel>
                  <TextBlock Grid.Column="2"
                             Text="{Binding ConnectedTime}"
                             FontSize="12"
                             Opacity="0.55"
                             VerticalAlignment="Center" />
                </Grid>
              </ui:FASettingsExpanderItem>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ui:FASettingsExpander>

      <ui:FASettingsExpander Header="{Binding AdvancedHeader}"
                           Description="{Binding AdvancedDescription}"
                           IsExpanded="False">

        <ui:FASettingsExpanderItem>
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <StackPanel Spacing="4">
              <TextBlock Text="{Binding PortConfigurationLabel}" FontWeight="SemiBold" />
              <TextBlock Text="{Binding PortConfigurationDescription}"
                         FontSize="12"
                         Opacity="0.65"
                         TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
              <RadioButton GroupName="PortMode"
                           Content="{Binding AutoPortText}"
                           IsChecked="{Binding IsAutoPort}" />
              <RadioButton GroupName="PortMode"
                           Content="{Binding ManualPortText}"
                           IsChecked="{Binding IsManualPort}" />
              <ui:FANumberBox Value="{Binding ManualPortNumber}"
                            Minimum="1024"
                            Maximum="65535"
                            Width="110"
                            IsVisible="{Binding IsManualPort}"
                            IsEnabled="{Binding !IsGatewayRunning}" />
            </StackPanel>
          </Grid>
        </ui:FASettingsExpanderItem>

        <ui:FASettingsExpanderItem>
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <StackPanel Spacing="4">
              <TextBlock Text="{Binding AutoRestartLabel}" FontWeight="SemiBold" />
              <TextBlock Text="{Binding AutoRestartDescription}"
                         FontSize="12"
                         Opacity="0.65"
                         TextWrapping="Wrap" />
            </StackPanel>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding AutoRestart}" />
          </Grid>
        </ui:FASettingsExpanderItem>

        <ui:FASettingsExpanderItem>
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <TextBlock Text="{Binding LogLevelLabel}" VerticalAlignment="Center" />
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding LogLevels}"
                      SelectedItem="{Binding SelectedLogLevel}"
                      Width="130">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:LogLevelOption">
                  <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </Grid>
        </ui:FASettingsExpanderItem>

        <ui:FASettingsExpanderItem>
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <StackPanel Spacing="4">
              <TextBlock Text="{Binding DebugModeLabel}" FontWeight="SemiBold" />
              <TextBlock Text="{Binding DebugModeDescription}"
                         FontSize="12"
                         Opacity="0.65"
                         TextWrapping="Wrap" />
            </StackPanel>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding DebugMode}" />
          </Grid>
        </ui:FASettingsExpanderItem>

        <ui:FASettingsExpanderItem>
          <Button Command="{Binding ResetSettingsCommand}"
                  Content="{Binding ResetText}"
                  HorizontalAlignment="Right" />
        </ui:FASettingsExpanderItem>
      </ui:FASettingsExpander>
    </StackPanel>
  </ScrollViewer>
</UserControl>
